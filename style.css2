body{
    font-family: Arial, sans-serif;
    background: #f4f4f4;
    display: flex;
    justify-content: center;
    margin-top: 50px;
}

.container{
    background: white;
    padding: 30px;
    width: 400px;
    border-radius: 10px;
    box-shadow: 0 0 10px gray;
}

h1{
    text-align: center;
}

label{
    display: block;
    margin-top: 15px;
}

input, select{
    width: 100%;
    padding: 10px;
    margin-top: 5px;
}

button{
    width: 100%;
    margin-top: 20px;
    padding: 10px;
    background: darkblue;
    color: white;
    border: none;
    cursor: pointer;
}

#ticket{
    margin-top: 20px;
    padding: 15px;
    border: 2px dashed black;
}